# Required for synthesis (LLM narrative paragraphs)
ANTHROPIC_API_KEY=sk-ant-...

# Optional — higher PubMed rate limits with key (3 req/s → 10 req/s)
NCBI_API_KEY=

# Required by SEC EDGAR — replace with your name + email
# SEC bans IPs that don't send a User-Agent header
EDGAR_USER_AGENT="Your Name your-email@example.com"
